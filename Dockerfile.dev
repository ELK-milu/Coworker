# Development Dockerfile
# 用于开发环境，支持热重载

FROM golang:1.24-alpine

# 安装必要的工具（包括 docker CLI 用于调用 nsjail 沙箱）
RUN apk add --no-cache git make bash curl docker-cli tzdata

# 配置 Go 代理（使用国内镜像）
ENV GOPROXY=https://goproxy.cn,direct
ENV GO111MODULE=on
ENV GOTOOLCHAIN=auto

# 安装 air 热重载工具（使用兼容 Go 1.24 的版本）
RUN go install github.com/air-verse/air@v1.60.0

# 设置工作目录
WORKDIR /app

# 复制 go.mod 和 go.sum（利用缓存）
COPY go.mod go.sum ./

# 下载依赖
RUN go mod download

# 复制源代码（开发时会被 volume 覆盖）
COPY . .

# 暴露端口
EXPOSE 3000

# 使用 air 启动（支持热重载）
CMD ["air", "-c", ".air.toml"]
